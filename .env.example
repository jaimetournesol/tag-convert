# Copy to .env and fill in. The CLI reads env first, then .env, then flags.

# --- Auth (pick one) ---
TAG_EMAIL=
TAG_PASSWORD=
# TAG_TOKEN=          # a TAG session JWT, instead of email/password

# --- Target instance (REQUIRED — get these from your TAG operator) ---
TAG_API_URL=https://your-tag-api.example.com
TAG_RELAY_URL=https://your-tag-relay.example.com
